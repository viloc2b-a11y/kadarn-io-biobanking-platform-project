{
  "uid": "kadarn-platform",
  "title": "Kadarn Platform",
  "tags": ["kadarn", "hardening", "sprint-7"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Health Checks",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (probe, status) (rate(kadarn_health_checks_total[5m]))",
          "legendFormat": "{{probe}} {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Pipeline Runs",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (pipeline) (rate(kadarn_pipeline_runs_total[5m]))",
          "legendFormat": "{{pipeline}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Domain Events Published",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (event_type) (rate(kadarn_domain_events_published_total[5m]))",
          "legendFormat": "{{event_type}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Pipeline Stage p95 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, pipeline) (rate(kadarn_pipeline_stage_duration_ms_bucket[5m])))",
          "legendFormat": "{{pipeline}}"
        }
      ]
    }
  ]
}
