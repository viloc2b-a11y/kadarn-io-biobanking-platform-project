# ==========================================================================
# Supabase Environment — Local Development
# ==========================================================================
# Copy this file to .env.local and fill in your Supabase project values.
# Never commit .env.local or any file containing real credentials.
# ==========================================================================

# --- Supabase Project ---
# Get these from your Supabase project dashboard:
#   Settings > API > Project URL
#   Settings > API > Project API keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- Server-side only ---
# These must NEVER be exposed to the browser.
# They are used in API routes (server-side) only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Database (direct connection) ---
# For migrations, seed scripts, and CLI tools.
# Never use this in API routes.
DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# --- Supabase CLI ---
# Used by `supabase start` and `supabase db` commands.
SUPABASE_PROJECT_ID=your-project-id

# --- Local Development only ---
# When running `supabase start`, these are auto-configured.
# Override only when connecting to a remote project.
# SUPABASE_URL=http://localhost:54321
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
