# ==========================================================================
# Kadarn API - Environment (local / staging / production)
# ==========================================================================
# Copy to apps/api/.env.local. Never commit real credentials.
# ==========================================================================

# --- Required (server-side API routes) ---
SUPABASE_URL=http://127.0.0.1:55421
SUPABASE_ANON_KEY=replace-with-anon-key-from-supabase-status
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key-from-supabase-status
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001

# --- Browser (if any client components need Supabase) ---
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55421
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key-from-supabase-status

# --- Sponsor Passport runtime source ---
# Local/demo: mock
# Staging/production: evidence-core
SPONSOR_PASSPORT_DATA_SOURCE=mock
# SPONSOR_PASSPORT_ALLOW_MOCK_IN_PRODUCTION=false

# --- Phase 8 cutover (Sprint 28K) ---
# false = Published View path active; Compatibility Layer code retained for rollback.
# LEGACY_PASSPORT_ENABLED=false

# --- PCP-1.1 production safety gates ---
# Production event publishing fails closed unless this emergency fallback is explicitly enabled.
# KADARN_ALLOW_DOMAIN_EVENT_FALLBACK=false
# Production rate limiting rejects in-memory mode unless explicitly accepted during rollout.
# KADARN_ALLOW_IN_MEMORY_RATE_LIMIT=false

# --- Production only ---
# SUPABASE_JWT_SECRET=replace-in-production

# --- Local dev / CLI (optional) ---
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55432/postgres
# SUPABASE_PROJECT_ID=your-local-project-id
# NODE_ENV=development
