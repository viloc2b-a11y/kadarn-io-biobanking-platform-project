{
  "title": "Kadarn — Latency & Errors",
  "panels": [
    { "title": "P50 latency", "targets": [{ "expr": "histogram_quantile(0.50, rate(kadarn_http_request_duration_seconds_bucket[5m]))" }] },
    { "title": "P95 latency", "targets": [{ "expr": "histogram_quantile(0.95, rate(kadarn_http_request_duration_seconds_bucket[5m]))" }] },
    { "title": "Errors by code", "targets": [{ "expr": "sum by (code) (rate(kadarn_http_errors_total[5m]))" }] }
  ]
}
